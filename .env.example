# Supabase
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Gemini
GEMINI_API_KEY=AIza...

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_BOT_TOKEN_PUBLIC=789012:XYZ...
TELEGRAM_CHAT_ID=123456789

# Video APIs
ELEVENLABS_API_KEY=sk_...
# Veo (Vertex picks output resolution). VEO_FPS defaults to 30 in code if unset.
VEO_COMPRESSION=optimized
VEO_FPS=30
# Trim soft start: VEO_TRIM_MODE=reencode (default) or copy; VEO_TRIM_START_SEC=0.35
# Pairwise xfade: VIDEO_XFADE_CRF, VIDEO_XFADE_PRESET, VIDEO_XFADE_TUNE=stillimage (or none to disable)
# FFmpeg H.264 (slideshow / Ken Burns): lower CRF = higher quality (18–23 typical)
VIDEO_H264_PRESET=medium
VIDEO_H264_CRF=20
VIDEO_AAC_BITRATE=192k
RESEND_API_KEY=re_...

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App URLs (update after deployment)
APP_URL=https://yourdomain.com
API_BASE_URL=https://api.yourdomain.com

# Configuration
VEO_DAILY_BUDGET_CAD=10.00
MAX_TELEGRAM_PHOTOS=15
# Video scene planner: max exterior shots (Railway: set to 1 for cleaner tours)
MAX_SCENE_EXTERIOR=1

# Crawling (Cloudflare / Firecrawl - bypass 403 on Realtor.ca, Condos.ca)
DEFAULT_CRAWL_BACKEND=cloudflare
CLOUDFLARE_ACCOUNT_ID=your-account-id-here
CLOUDFLARE_API_TOKEN=your-api-token-here
# FIRECRAWL_API_KEY=fc-your-api-key-here

